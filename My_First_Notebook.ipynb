import json
from datetime import datetime
jupyter nbconvert --to notebook --stdout "My_First_Notebook.ipynb" > "Fixed_Notebook.ipynb"


def initialize_course_environment():
    # Famous standard greeting to confirm execution pipeline
    print("----------------------------------------")
    print("  SYSTEM MESSAGE: Hello, World!!!")
    print("----------------------------------------")
    
    # Define your course attributes
    course_attributes = {
        "course_id": "ITAI1378",
        "lab_title": "Jupyter Exploration",
        "student_name": "Michael Rivas",
        "submission_date": datetime.now().strftime("%Y-%m-%d"),
        "repository": "jupyter-exploration",
        "status": "production_ready"
    }
    
    # Save to a JSON file for your repository
    with open('course_metadata.json', 'w') as f:
        json.dump(course_attributes, f, indent=4)
        
    return course_attributes

# Execute the setup
metadata = initialize_course_environment()
print("ENVIRONMENT INITIALIZED SUCCESSFULLY.")
print(f"Tracking: {metadata['lab_title']} for {metadata['course_id']}")
